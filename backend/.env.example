# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=padel_tournament

# JWT - IMPORTANTE: Cambiar en producción
# Genera un secret seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambiar-este-secreto-en-produccion

# Application
PORT=3000
NODE_ENV=development

# ── Twilio (WhatsApp / SMS Notifications) ────────────────────────────────────
# Obtén tus credenciales en: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox WhatsApp number (default Twilio sandbox: +14155238886)
# En producción usa tu número aprobado por WhatsApp Business
TWILIO_WHATSAPP_FROM=